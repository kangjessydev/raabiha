[
    {
        "id": 101,
        "title": "Raabiha Hero Banner",
        "icon": "<svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"24\" height=\"24\" viewbox=\"0 0 24 24\"><path d=\"M19 12h-2v3h-3v2h5v-5zM7 9h3V7H5v5h2V9zm14-6H3c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16.01H3V4.99h18v14.02z\"><\/path><\/svg>",
        "slug": "lazyblock\/raabiha-hero-banner",
        "description": "Hero section with background image, title, subtitle, and CTA button.",
        "category": "raabiha-blocks",
        "category_label": "Raabiha Premium Blocks",
        "supports": {
            "customClassName": true,
            "anchor": true,
            "html": false,
            "multiple": true,
            "inserter": true,
            "reusable": true,
            "align": ["wide", "full"]
        },
        "controls": [
            {
                "type": "image",
                "name": "bg_image",
                "label": "Background Image",
                "placement": "inspector",
                "width": "100"
            },
            {
                "type": "text",
                "name": "title",
                "label": "Headline Title",
                "default": "ARCHITECTURAL MODESTY",
                "placement": "inspector",
                "width": "100"
            },
            {
                "type": "textarea",
                "name": "subtitle",
                "label": "Subtitle",
                "default": "Mendefinisikan ulang kemewahan melalui kesederhanaan.",
                "placement": "inspector",
                "width": "100"
            },
            {
                "type": "text",
                "name": "button_text",
                "label": "Button Text",
                "default": "SHOP THE COLLECTION",
                "placement": "inspector",
                "width": "100"
            },
            {
                "type": "url",
                "name": "button_url",
                "label": "Button Link",
                "default": "#",
                "placement": "inspector",
                "width": "100"
            }
        ],
        "code": {
            "output_method": "html",
            "frontend_html": "<section useBlockProps class=\"relative h-[80vh] min-h-[600px] flex items-center justify-center overflow-hidden\">\n    {{#if bg_image}}\n    <img src=\"{{bg_image.url}}\" alt=\"{{title}}\" class=\"absolute inset-0 w-full h-full object-cover\" />\n    {{\/if}}\n    <div class=\"absolute inset-0 bg-black\/30\"><\/div>\n    \n    <div class=\"relative z-10 text-center px-6 max-w-4xl mx-auto\">\n        <h1 class=\"font-playfair text-4xl md:text-6xl lg:text-7xl font-bold text-white mb-6 tracking-tight opacity-0 animate-fade-in-up\">\n            {{title}}\n        <\/h1>\n        <p class=\"font-inter text-lg md:text-xl text-neutral-200 mb-10 max-w-2xl mx-auto font-light opacity-0 animate-fade-in-up\" style=\"animation-delay: 200ms;\">\n            {{subtitle}}\n        <\/p>\n        <a href=\"{{button_url}}\" class=\"inline-block bg-white text-neutral-900 px-8 py-4 uppercase tracking-widest text-sm font-semibold hover:bg-neutral-900 hover:text-white transition-colors duration-500 opacity-0 animate-fade-in-up\" style=\"animation-delay: 400ms;\">\n            {{button_text}}\n        <\/a>\n    <\/div>\n<\/section>",
            "show_preview": "always",
            "single_output": true
        }
    },
    {
        "id": 102,
        "title": "Raabiha Featured Categories",
        "icon": "<svg xmlns=\"http:\/\/www.w3.org\/2000\/svg\" width=\"24\" height=\"24\" viewbox=\"0 0 24 24\"><path d=\"M4 6h16v2H4zm0 5h16v2H4zm0 5h16v2H4z\"><\/path><\/svg>",
        "slug": "lazyblock\/raabiha-featured-categories",
        "description": "3-column featured categories block.",
        "category": "raabiha-blocks",
        "category_label": "Raabiha Premium Blocks",
        "supports": {
            "customClassName": true,
            "anchor": true,
            "html": false,
            "multiple": true,
            "inserter": true,
            "reusable": true,
            "align": ["wide", "full"]
        },
        "controls": [
            {
                "type": "repeater",
                "name": "categories",
                "label": "Categories",
                "placement": "inspector",
                "width": "100",
                "rows_label": "Category"
            },
            {
                "type": "image",
                "name": "image",
                "label": "Category Image",
                "child_of": "control_categories",
                "placement": "inspector",
                "width": "100"
            },
            {
                "type": "text",
                "name": "title",
                "label": "Category Title",
                "child_of": "control_categories",
                "placement": "inspector",
                "width": "100"
            },
            {
                "type": "url",
                "name": "link",
                "label": "Category Link",
                "child_of": "control_categories",
                "placement": "inspector",
                "width": "100"
            }
        ],
        "code": {
            "output_method": "html",
            "frontend_html": "<section useBlockProps class=\"py-24 bg-white\">\n    <div class=\"max-w-7xl mx-auto px-6\">\n        <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n            {{#each categories}}\n            <a href=\"{{link}}\" class=\"group block relative h-[500px] overflow-hidden\">\n                {{#if image}}\n                <img src=\"{{image.url}}\" alt=\"{{title}}\" class=\"absolute inset-0 w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105\" />\n                {{\/if}}\n                <div class=\"absolute inset-0 bg-gradient-to-t from-black\/60 via-black\/0 to-black\/0\"><\/div>\n                <div class=\"absolute bottom-8 left-8 right-8 flex justify-between items-end\">\n                    <h3 class=\"font-playfair text-3xl text-white\">{{title}}<\/h3>\n                    <span class=\"text-white opacity-0 transform translate-x-4 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0\">\n                        <svg class=\"w-6 h-6\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\">\n                            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M17 8l4 4m0 0l-4 4m4-4H3\"><\/path>\n                        <\/svg>\n                    <\/span>\n                <\/div>\n            <\/a>\n            {{\/each}}\n        <\/div>\n    <\/div>\n<\/section>",
            "show_preview": "always",
            "single_output": true
        }
    }
]
