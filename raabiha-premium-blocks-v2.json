            "frontend_html": "<?php\n$limit = isset($attributes['limit']) && !empty($attributes['limit']) ? intval($attributes['limit']) : 4;\n$title = isset($attributes['title']) ? $attributes['title'] : 'New Arrivals';\n$subtitle = isset($attributes['subtitle']) ? $attributes['subtitle'] : '';\n\n$args = array(\n    'post_type' => 'product',\n    'posts_per_page' => $limit,\n    'post_status' => 'publish',\n);\n$query = new WP_Query($args);\n?>\n<section useBlockProps class=\"py-24 bg-white\">\n    <div class=\"max-w-7xl mx-auto px-6\">\n        <div class=\"text-center mb-16\">\n            <h2 class=\"font-playfair text-4xl text-neutral-900 mb-4\"><?php echo esc_html($title); ?></h2>\n            <?php if($subtitle): ?>\n                <p class=\"font-inter text-neutral-500 tracking-wider uppercase text-sm\"><?php echo esc_html($subtitle); ?></p>\n            <?php endif; ?>\n        </div>\n        <?php if ($query->have_posts()) : ?>\n            <div class=\"grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-12\">\n                <?php while ($query->have_posts()) : $query->the_post(); global $product; ?>\n                    <a href=\"<?php the_permalink(); ?>\" class=\"group block\">\n                        <div class=\"relative aspect-[3/4] overflow-hidden bg-neutral-100 mb-4\">\n                            <?php echo woocommerce_get_product_thumbnail('woocommerce_thumbnail', ['class' => 'w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700']); ?>\n                            <?php if ($product->is_on_sale()) : ?>\n                                <span class=\"absolute top-3 right-3 bg-red-600 text-white text-xs font-bold px-2 py-1 uppercase tracking-wider\">\n                                    Sale\n                                </span>\n                            <?php endif; ?>\n                        </div>\n                        <h3 class=\"font-playfair text-lg text-neutral-900 mb-1\"><?php the_title(); ?></h3>\n                        <div class=\"font-inter text-sm text-neutral-600\">\n                            <?php echo $product->get_price_html(); ?>\n                        </div>\n                    </a>\n                <?php endwhile; wp_reset_postdata(); ?>\n            </div>\n        <?php else: ?>\n            <p class=\"text-center text-neutral-500\">No products found.</p>\n        <?php endif; ?>\n    </div>\n</section>",
